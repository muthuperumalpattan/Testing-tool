# Required — PostgreSQL connection string (Neon, Supabase, Render Postgres, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Northflank injects PORT automatically; default is 5000
PORT=5000

NODE_ENV=production

# Optional — system Chromium path (set in Dockerfile by default)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
CHROME_PATH=/usr/bin/chromium
